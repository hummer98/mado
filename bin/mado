#!/usr/bin/env bash
# mado: Electrobun launcher ラッパー
#
# launcher は CLI 引数を bun 子プロセスへ forwarding しない Zig バイナリのため、
# ファイルパスは環境変数 MADO_FILE 経由で渡す。
# 呼び出し元 cwd を基準に絶対パス化する責務を持つ（bun 側は受け取った値を
# そのまま path.resolve() に通す）。
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# --version / -v: package.json からバージョンを読んで表示して終了
if [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; then
  PKG_JSON="$PROJECT_ROOT/package.json"
  if command -v jq >/dev/null 2>&1; then
    VERSION="$(jq -r '.version' "$PKG_JSON")"
  else
    VERSION="$(grep '"version"' "$PKG_JSON" | sed 's/.*"version": *"\([^"]*\)".*/\1/')"
  fi
  echo "mado $VERSION"
  exit 0
fi

# macOS arm64 dev ビルド前提。将来 x64/Linux 対応時はパス検出を柔軟化する
LAUNCHER="$PROJECT_ROOT/build/dev-macos-arm64/mado-dev.app/Contents/MacOS/launcher"

if [ ! -x "$LAUNCHER" ]; then
  echo "[mado] launcher が見つかりません。bun run build:dev を実行してください。" >&2
  exit 1
fi

# 引数がある場合のみ MADO_FILE をエクスポートする。
# 引数が無ければ MADO_FILE は未設定のまま launcher を起動し、
# bun 側では welcome モード (Task 020) で起動する。
if [ -n "${1:-}" ]; then
  if [[ "$1" = /* ]]; then
    MADO_FILE="$1"
  else
    MADO_FILE="$(pwd)/$1"
  fi
  export MADO_FILE
fi

if [ "${MADO_FOREGROUND:-}" = "1" ]; then
  # 前景モード: 従来動作。Ctrl+C で落ちる、stdout/stderr 直結。
  exec "$LAUNCHER"
else
  # デタッチモード（デフォルト）: シェルを即解放、SIGHUP 遮断。
  # ログディレクトリは src/lib/logger.ts の getLogDir() と同じ優先順位で算出する。
  # （logger.ts の getLogDir() を変更したらここも追従させること）
  if [ -n "${MADO_LOG_DIR:-}" ]; then
    LOG_DIR="$MADO_LOG_DIR"
  else
    LOG_DIR="${TMPDIR:-/tmp/}"
    LOG_DIR="${LOG_DIR%/}/mado"
  fi
  echo "[mado] log dir: $LOG_DIR (latest: ls -t \"$LOG_DIR\" | head -1)" >&2
  ( nohup "$LAUNCHER" </dev/null >/dev/null 2>&1 & disown ) &
fi
